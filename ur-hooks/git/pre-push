#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook: run CI checks, build images, and run acceptance tests.
# Install with: cargo make install-hooks
#
# Output is captured to a stable log file. The log is removed on success
# and preserved on failure so you can read the full output.

mkdir -p tmp
LOGFILE=$(mktemp tmp/ur-pre-push.XXXXXX)

# Capture the branch being pushed from stdin (format: <local ref> <local sha> <remote ref> <remote sha>)
while IFS=' ' read -r local_ref _local_sha _remote_ref _remote_sha; do
    export UR_PUSH_BRANCH="${local_ref#refs/heads/}"
    break
done

run_step() {
    local label="$1"
    shift
    if ! "$@" >>"$LOGFILE" 2>&1; then
        echo "pre-push FAILED: $label" >&2
        echo "--- last 100 lines (full log: $LOGFILE) ---" >&2
        tail -100 "$LOGFILE" >&2
        exit 1
    fi
}

run_step "Cargo.lock check" cargo check --locked --quiet
run_step "CI (fmt + clippy + build + test)" cargo make ci
run_step "image build + acceptance" cargo make acceptance-ci

rm -f "$LOGFILE"
