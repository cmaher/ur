#!/usr/bin/env bash
set -euo pipefail

# Pre-push hook: run CI checks, build images, and run acceptance tests.
# Install with: cargo make install-hooks
#
# All command output is suppressed; only the failing step is reported.
# To see full output, run the failing command manually.

LOGFILE=$(mktemp /tmp/ur-pre-push.XXXXXX)
trap 'rm -f "$LOGFILE"' EXIT

run_step() {
    local label="$1"
    shift
    if ! "$@" >"$LOGFILE" 2>&1; then
        echo "pre-push FAILED: $label"
        echo "--- last 30 lines ---"
        tail -30 "$LOGFILE"
        exit 1
    fi
}

run_step "Cargo.lock check" cargo check --locked --quiet
run_step "CI (fmt + clippy + build + test)" cargo make ci
run_step "cargo audit" cargo audit

# --- Mutex: only one pre-push hook runs image builds/acceptance at a time ---
LOCK_DIR="${UR_CONFIG:-$HOME/.ur}/locks/pre-push"
PID_FILE="$LOCK_DIR/pid"

release_lock() {
    rm -rf "$LOCK_DIR"
}

acquire_lock() {
    while true; do
        if mkdir "$LOCK_DIR" 2>/dev/null; then
            echo $$ > "$PID_FILE"
            trap 'release_lock; rm -f "$LOGFILE"' EXIT
            return
        fi

        if [ -f "$PID_FILE" ]; then
            local stale_pid
            stale_pid=$(cat "$PID_FILE" 2>/dev/null || true)
            if [ -n "$stale_pid" ] && ! kill -0 "$stale_pid" 2>/dev/null; then
                rm -rf "$LOCK_DIR"
                continue
            fi
        fi

        echo "pre-push: waiting for lock (PID $(cat "$PID_FILE" 2>/dev/null || echo '?'))..."
        sleep 10
    done
}

mkdir -p "$(dirname "$LOCK_DIR")"
acquire_lock

run_step "image build" cargo make image
run_step "acceptance tests" cargo test -p acceptance --features acceptance
