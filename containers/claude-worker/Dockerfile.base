FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    tmux \
    curl \
    ca-certificates \
    coreutils \
    jq \
    less \
    make \
    python3 \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user (Claude Code refuses --dangerously-skip-permissions as root)
RUN useradd -m -s /bin/bash worker

# Install Claude Code CLI as root (script is cached locally, binary downloaded at build time)
COPY install-claude.sh /tmp/install-claude.sh
RUN bash /tmp/install-claude.sh && rm /tmp/install-claude.sh \
    && chmod -R o+rX /root/.local
